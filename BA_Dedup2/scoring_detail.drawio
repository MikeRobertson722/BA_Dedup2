        </mxCell>
        <mxCell id="a_exact_y" edge="1" parent="1" source="nc_exact" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" target="nc_exact_yes" value="YES">
