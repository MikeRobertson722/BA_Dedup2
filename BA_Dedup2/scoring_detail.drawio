<mxfile host="app.diagrams.net" modified="2026-02-26" agent="Claude" version="24.0.0" type="device">
  <diagram id="scoring-detail" name="Name &amp; Address Scoring">
    <mxGraphModel dx="2200" dy="2800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3300" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========== TITLE ========== -->
        <mxCell id="title" value="BA Dedup2 — Name &amp; Address Scoring Detail" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="400" y="-30" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- NAME SCORING (Left Side)                                         -->
        <!-- ================================================================ -->
        <mxCell id="name_header" value="NAME SCORING" style="text;html=1;fontSize=18;fontStyle=1;align=center;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="140" y="30" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 1: normalize_name() -->
        <mxCell id="name_norm_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="700" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="name_norm_title" value="&lt;b&gt;Step 1: normalize_name()&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="240" y="75" width="300" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="nn0" value="&lt;b&gt;Trust mode:&lt;/b&gt; if trust=True → just UPPERCASE + collapse whitespace, skip all below" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="105" width="620" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="nn1" value="Replace &lt;b&gt;/ &amp;amp;&lt;/b&gt; with space" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="nn2" value="Strip special chars &lt;code&gt;[^A-Za-z0-9\s]&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="140" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="nn3" value="UPPERCASE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="140" width="120" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="nn4" value="&lt;b&gt;Suffix Map Replacements&lt;/b&gt;&lt;br&gt;FEDERAL EXPRESS → FEDEX&lt;br&gt;Multi-word states: NEW YORK → NEWYORK&lt;br&gt;Trust: LIV TR → LIVING TRUST, REV/REVOC → REVOCABLE, TR → TRUST&lt;br&gt;CORPORATION → CORP, JUNIOR → JR, SENIOR → SR&lt;br&gt;L L C → LLC, L P → LP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="310" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="nn5" value="Split concatenated Roman&lt;br&gt;&lt;code&gt;PDIII → PD III&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="180" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="nn6" value="Collapse single letters&lt;br&gt;&lt;code&gt;J V S LLC → JVS LLC&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="230" width="230" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="nn7" value="&lt;b&gt;Output: normalized name string&lt;/b&gt;" style="text;html=1;fontSize=11;fontColor=#555;align=center;" vertex="1" parent="1">
          <mxGeometry x="140" y="285" width="500" height="20" as="geometry"/>
        </mxCell>

        <!-- Arrow: norm → compare -->
        <mxCell id="a_n1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="name_norm_group" target="name_cmp_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 2: name_compare() -->
        <mxCell id="name_cmp_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="700" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="name_cmp_title" value="&lt;b&gt;Step 2: name_compare()&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="240" y="355" width="300" height="25" as="geometry"/>
        </mxCell>

        <!-- Exact match check -->
        <mxCell id="nc_exact" value="Normalized strings equal?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="390" width="230" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="nc_exact_yes" value="&lt;b&gt;Score = 100&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="395" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_exact_y" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" edge="1" parent="1" source="nc_exact" target="nc_exact_yes">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tokenize & strip -->
        <mxCell id="nc_token" value="&lt;b&gt;Tokenize &amp;amp; Clean Tokens&lt;/b&gt;&lt;br&gt;1. Strip NAME_SUFFIXES: JR, SR, II, III, IV, V&lt;br&gt;2. Acronym check: CSC = Corp Service Co → &lt;b&gt;95&lt;/b&gt;&lt;br&gt;3. Strip BUSINESS_SUFFIXES: LLC, INC, CORP, CO, LTD, LP...&lt;br&gt;4. Strip BUSINESS_DESCRIPTORS: SERVICES, HOLDINGS...&lt;br&gt;5. Strip &lt;b&gt;INDUSTRY_TERMS&lt;/b&gt;: EXPLORATION, DRILLING, OIL, GAS,&lt;br&gt;   PETROLEUM, ENERGY, RESOURCES, PIPELINE, MINERALS...&lt;br&gt;6. Strip AND, THE&lt;br&gt;7. &lt;b&gt;canonicalize_token()&lt;/b&gt; each remaining token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="455" width="380" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="a_exact_n" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=10;" edge="1" parent="1" source="nc_exact" target="nc_token">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- canonicalize_token detail -->
        <mxCell id="nc_canon" value="&lt;b&gt;canonicalize_token()&lt;/b&gt;&lt;br&gt;NICKNAMES: JIMMY→JAMES, BOB→ROBERT...&lt;br&gt;NUMBER_WORDS: ONE→1, TWO→2...&lt;br&gt;STATE_ABBREVS: TX→TEXAS, OK→OKLAHOMA...&lt;br&gt;(skip IN, CO — ambiguous)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="490" y="460" width="230" height="85" as="geometry"/>
        </mxCell>

        <!-- Post-strip exact check -->
        <mxCell id="nc_post_exact" value="Cleaned tokens equal?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="600" width="230" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_tok_to_post" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=1.5;" edge="1" parent="1" source="nc_token" target="nc_post_exact">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="nc_post_yes" value="&lt;b&gt;Score = 100&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="605" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_post_y" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" edge="1" parent="1" source="nc_post_exact" target="nc_post_yes">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Initial match check -->
        <mxCell id="nc_initial" value="Initial-match?&lt;br&gt;&lt;font size=&quot;1&quot;&gt;J SMITH = JOHN SMITH&lt;br&gt;(2+ tokens, single-letter first + same last)&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="665" width="270" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="a_post_n" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=10;" edge="1" parent="1" source="nc_post_exact" target="nc_initial">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="nc_init_yes" value="&lt;b&gt;Score = 95&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="675" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_init_y" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" edge="1" parent="1" source="nc_initial" target="nc_init_yes">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Similarity engine -->
        <mxCell id="nc_sim" value="&lt;b&gt;Multi-Strategy Similarity&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="180" y="740" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="a_init_n" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=10;" edge="1" parent="1" source="nc_initial" target="nc_sim">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="nc_jw1" value="&lt;b&gt;Direct JW&lt;/b&gt;&lt;br&gt;jaro_winkler(c1, c2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="nc_jw2" value="&lt;b&gt;Sorted JW&lt;/b&gt;&lt;br&gt;sort tokens alphabetically" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="770" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="nc_jw3" value="&lt;b&gt;Compact JW&lt;/b&gt;&lt;br&gt;strip all non-alnum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="770" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="nc_best_jw" value="&lt;b&gt;best_jw = max(direct, sorted, compact)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="155" y="825" width="380" height="30" as="geometry"/>
        </mxCell>

        <!-- Token overlap -->
        <mxCell id="nc_overlap" value="&lt;b&gt;enhanced_token_overlap()&lt;/b&gt;&lt;br&gt;1. Exact token match&lt;br&gt;2. Initial match (J ↔ JOHN)&lt;br&gt;3. Fuzzy match (JW &amp;gt; 0.88, both tokens &amp;gt; 4 chars)&lt;br&gt;&lt;b&gt;Result:&lt;/b&gt; overlap_coeff = matched / smaller_set_size" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="870" width="340" height="80" as="geometry"/>
        </mxCell>

        <!-- Bookend bonus -->
        <mxCell id="nc_bookend" value="&lt;b&gt;Bookend Bonus&lt;/b&gt;&lt;br&gt;If first tokens match (exact, initial, &lt;br&gt;or JW ≥ 0.85) AND last tokens match:&lt;br&gt;&lt;b&gt;overlap_coeff = max(overlap, 0.90)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="870" width="290" height="75" as="geometry"/>
        </mxCell>

        <!-- Final score formula -->
        <mxCell id="nc_formula" value="&lt;b&gt;score = best_jw × (0.3 + 0.7 × overlap_coeff)&lt;/b&gt;&lt;br&gt;&lt;br&gt;If compact_jw ≥ 0.95: score = max(score, compact_jw)&lt;br&gt;&lt;br&gt;&lt;b&gt;Round to nearest 5, scale to 0–100&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="960" width="420" height="70" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- ADDRESS-NAME BOOST (between name scoring and address scoring)    -->
        <!-- ================================================================ -->
        <mxCell id="boost_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="1050" width="700" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="boost_title" value="&lt;b&gt;Address-Name Boost (supplementary name sources, capped at 0.95)&lt;/b&gt;" style="text;html=1;fontSize=13;align=center;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="140" y="1055" width="500" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="boost_sources" value="&lt;b&gt;If primary name_score &amp;lt; 0.95, check supplementary sources (best wins):&lt;/b&gt;&lt;br&gt;1. DEC_CONTACT: Canvas name vs DEC addrcontact field&lt;br&gt;2. CANVAS_ADDR_NAME: names from Canvas address (C/O, ATTN patterns) vs DEC hdrname&lt;br&gt;3. CANVAS_ADDR+DEC_CONTACT: Canvas address names vs DEC addrcontact&lt;br&gt;4. DEC_ADDR_NAME: Canvas name vs names from DEC address field&lt;br&gt;5. CANVAS_ADDR+DEC_ADDR: Canvas address names vs DEC address names" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="1085" width="400" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="boost_extract" value="&lt;b&gt;Name Extraction from Addresses:&lt;/b&gt;&lt;br&gt;• C/O &amp;lt;name&amp;gt; (before digits/PO BOX)&lt;br&gt;• ATTN: &amp;lt;name&amp;gt; (before digits/PO BOX)&lt;br&gt;• Strip role suffixes: MANAGER, AGENT,&lt;br&gt;  DIRECTOR, PRESIDENT, VP, etc." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="1085" width="240" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="boost_note" value="All supplementary scores capped at &lt;b&gt;0.95&lt;/b&gt; — only applied if better than primary name_compare result" style="text;html=1;fontSize=10;fontColor=#5C6BC0;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="1195" width="580" height="15" as="geometry"/>
        </mxCell>

        <!-- Arrow: name formula → boost -->
        <mxCell id="a_name_to_boost" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#5C6BC0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="nc_formula" target="boost_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- ADDRESS SCORING (Right Side)                                     -->
        <!-- ================================================================ -->
        <mxCell id="addr_header" value="ADDRESS SCORING" style="text;html=1;fontSize=18;fontStyle=1;align=center;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="900" y="30" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 1: normalize_address() -->
        <mxCell id="addr_norm_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="70" width="720" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="addr_norm_title" value="&lt;b&gt;Step 1: normalize_address()&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="1000" y="75" width="300" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="an0" value="&lt;b&gt;Trust mode:&lt;/b&gt; if trust=True → just UPPERCASE + collapse whitespace, skip all below" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="820" y="105" width="680" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="an_dates" value="&lt;b&gt;Strip Dates&lt;/b&gt;&lt;br&gt;Remove DATED prefix&lt;br&gt;Strip: JUNE 14 2012, MAR 2012&lt;br&gt;Strip: MM/DD/YYYY, MM-DD-YYYY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="140" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="an1" value="&lt;b&gt;PO Box Canonicalization&lt;/b&gt;&lt;br&gt;POST OFFICE BOX / P.O. BOX → PO BOX&lt;br&gt;POB / POP BOX → PO BOX&lt;br&gt;BOX 5 → PO BOX 5 (if entire line)&lt;br&gt;PO BOX ONE → PO BOX 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1040" y="140" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="an2" value="&lt;b&gt;Direction Normalization&lt;/b&gt;&lt;br&gt;NORTHEAST → NE, NORTH → N&lt;br&gt;SOUTH → S, EAST → E, WEST → W" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1280" y="140" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="an3" value="&lt;b&gt;Street Type Abbreviation&lt;/b&gt;&lt;br&gt;STREET→ST, AVENUE→AVE, BOULEVARD→BLVD&lt;br&gt;DRIVE→DR, ROAD→RD, LANE→LN, COURT→CT&lt;br&gt;HIGHWAY→HWY, PARKWAY→PKWY, TRAIL→TRL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="220" width="250" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="an4" value="&lt;b&gt;Unit Abbreviation&lt;/b&gt;&lt;br&gt;APARTMENT→APT, SUITE→STE&lt;br&gt;BUILDING→BLDG, FLOOR→FL, ROOM→RM&lt;br&gt;#123 → APT 123" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1090" y="220" width="220" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="an5" value="&lt;b&gt;COUNTY ROAD → CR&lt;/b&gt;&lt;br&gt;(before street type norm)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1330" y="220" width="170" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="an6" value="Strip &lt;b&gt;. , -&lt;/b&gt; and collapse spaces" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="260" width="190" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="an_strip_names" value="&lt;b&gt;Strip Leading Names&lt;/b&gt;&lt;br&gt;If addr doesn't start with digit/PO BOX:&lt;br&gt;find first digit pattern, strip words before it&lt;br&gt;(preserves HWY, CR, RR, RT, CMR, etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="296" width="340" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrow: norm → classify -->
        <mxCell id="a_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="addr_norm_group" target="addr_classify">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 2: address_compare() - classify address type -->
        <mxCell id="addr_classify" value="&lt;b&gt;Classify Address Type&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1040" y="380" width="230" height="60" as="geometry"/>
        </mxCell>

        <!-- PO Box branch -->
        <mxCell id="addr_pobox_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#b85450;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="490" width="340" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="addr_pobox_title" value="&lt;b&gt;PO Box Path&lt;/b&gt;" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="900" y="495" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a_classify_po" value="PO BOX" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=10;" edge="1" parent="1" source="addr_classify" target="addr_pobox_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="po1" value="Both PO Box?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="525" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="po1_no" value="Score=0&lt;br&gt;POBOX_VS_STREET" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="820" y="580" width="110" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_po1_no" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" edge="1" parent="1" source="po1" target="po1_no">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="po1b" value="Either box # missing?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="620" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_po1_yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="po1" target="po1b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="po1b_yes" value="Score=0&lt;br&gt;POBOX_MISSING_NUM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="820" y="670" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_po1b_yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" edge="1" parent="1" source="po1b" target="po1b_yes">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="po2" value="Box numbers match?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="715" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_po1b_no" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="po1b" target="po2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="po2_no" value="Score=0&lt;br&gt;POBOX_NUM_MISMATCH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="820" y="760" width="130" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_po2_no" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" edge="1" parent="1" source="po2" target="po2_no">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="po3" value="&lt;b&gt;Score = min(1.0, 0.92 × city_sim + zip_bonus)&lt;/b&gt;&lt;br&gt;zip_bonus = 0.05 if zips match&lt;br&gt;same = score ≥ 0.90 &amp;amp; city_sim ≥ 0.85" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="960" y="760" width="290" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_po2_yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="po2" target="po3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Street address branch -->
        <mxCell id="addr_street_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1180" y="490" width="380" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="addr_street_title" value="&lt;b&gt;Street Address Path&lt;/b&gt;" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1300" y="495" width="160" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a_classify_st" value="STREET" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" edge="1" parent="1" source="addr_classify" target="addr_street_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="st0" value="Either has house number?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="525" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- No house number: non-standard path -->
        <mxCell id="st_nonstandard" value="&lt;b&gt;Non-Standard Path&lt;/b&gt;&lt;br&gt;(military: CMR/PSC/UNIT)&lt;br&gt;&lt;br&gt;addr_sim = max(JW(addr1,addr2), JW(compact1,compact2))&lt;br&gt;score = addr_sim × (0.6 + 0.4 × city_sim)&lt;br&gt;&lt;br&gt;Penalties:&lt;br&gt;  • embedded nums mismatch: −0.10&lt;br&gt;  • zip mismatch: −0.20&lt;br&gt;Bonus:&lt;br&gt;  • all nums match + zip match: +0.50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1200" y="580" width="230" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="a_st0_no" value="NEITHER" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;fontSize=9;" edge="1" parent="1" source="st0" target="st_nonstandard">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- One missing -->
        <mxCell id="st_one_missing" value="Score=0&lt;br&gt;MISSING_HOUSE_NUM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1440" y="580" width="110" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_st0_one" value="ONE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" edge="1" parent="1" source="st0" target="st_one_missing">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- House numbers match -->
        <mxCell id="st1" value="House numbers match?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="745" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_st0_both" value="BOTH" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="st0" target="st1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1370" y="730"/>
              <mxPoint x="1380" y="730"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="st1_no" value="Score=0&lt;br&gt;HOUSE_NUM_MISMATCH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1440" y="740" width="110" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_st1_no" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" edge="1" parent="1" source="st1" target="st1_no">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Street core comparison -->
        <mxCell id="st_core" value="&lt;b&gt;street_core_for_match()&lt;/b&gt;&lt;br&gt;Strip: house num, street types,&lt;br&gt;directions, unit tokens&lt;br&gt;→ pure street name" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="805" width="220" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="a_st1_yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="st1" target="st_core">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Street formula -->
        <mxCell id="st_formula" value="&lt;b&gt;street_sim&lt;/b&gt; = max(JW(core1,core2), JW(compact1,compact2))&lt;br&gt;&lt;b&gt;city_sim&lt;/b&gt; = max(JW(city1,city2), JW(compact_cities))&lt;br&gt;&lt;br&gt;&lt;b&gt;score = street_sim × (0.6 + 0.4 × city_sim)&lt;/b&gt;&lt;br&gt;&lt;br&gt;If zip match &amp;amp; score ≥ 0.85: &lt;b&gt;+0.05&lt;/b&gt;&lt;br&gt;If zip mismatch &amp;amp; city_sim &amp;lt; 0.92: &lt;b&gt;×0.75&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;same = street_sim ≥ 0.90 &amp;amp; zip_ok &amp;amp; city_sim ≥ 0.85&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="890" width="340" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="a_core_to_formula" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1.5;" edge="1" parent="1" source="st_core" target="st_formula">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- GOOGLE ADDRESS API POST-PROCESSING                                -->
        <!-- ================================================================ -->
        <mxCell id="google_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="1060" width="1100" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="google_title" value="&lt;b&gt;Address API Override — Post-Processing&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="500" y="1065" width="560" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="google_filter" value="&lt;b&gt;Filter:&lt;/b&gt; SSN match (ssn_match=100) AND&lt;br&gt;  addr_score 15–65 (GOOGLE_ADDR_SCORE_MIN/MAX)&lt;br&gt;  &lt;b&gt;OR zero-score rule:&lt;/b&gt; score=0 but zips match,&lt;br&gt;  all embedded nums match, both have ≥1 number" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1100" width="320" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="google_validate" value="&lt;b&gt;google_validate_address()&lt;/b&gt;&lt;br&gt;1. Check in-memory cache (pre-loaded from SQLite)&lt;br&gt;2. Call Google Address Validation API if miss&lt;br&gt;3. Persist to google_address_lookups table&lt;br&gt;4. Return: standardized (addr,city,state,zip) + verdict JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2DFDB;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1175" width="340" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="google_cache" value="&lt;b&gt;Persistent Cache: google_address_lookups&lt;/b&gt;&lt;br&gt;Key: (input_address, city, state, zip)&lt;br&gt;success → cached permanently (never re-called)&lt;br&gt;failed → cached permanently&lt;br&gt;quota_error → retried on next run&lt;br&gt;&lt;b&gt;Run 2+: 0 API calls — all from cache&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="1100" width="330" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="google_rescore" value="&lt;b&gt;Re-score &amp;amp; Reclassify&lt;/b&gt;&lt;br&gt;1. Save originals → before_lookup_* columns&lt;br&gt;2. Replace Canvas + DEC addresses with standardized&lt;br&gt;3. Re-run address_compare() on standardized pair&lt;br&gt;4. If |new_score − old_score| ≥ 10 → override &amp;amp; reclassify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2DFDB;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="1205" width="330" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="google_audit" value="&lt;b&gt;Audit Columns (per record):&lt;/b&gt;&lt;br&gt;before_lookup_address/city/state/zip (Canvas)&lt;br&gt;before_lookup_dec_address/city/state/zip (DEC)&lt;br&gt;address_looked_up, dec_address_looked_up&lt;br&gt;canvas_lookup_verdict, dec_lookup_verdict (JSON)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1000" y="1100" width="320" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrow: scoring to Google -->
        <mxCell id="a_addr_to_google" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#00897B;strokeWidth=2;dashed=1;" edge="1" parent="1" source="st_formula" target="google_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- FINAL CLASSIFICATION (Bottom)                                    -->
        <!-- ================================================================ -->
        <mxCell id="final_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="250" y="1300" width="1100" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="final_title" value="&lt;b&gt;Final Classification — Configurable BUCKET_RULES (from Snowflake BA_CONFIG)&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="420" y="1305" width="700" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="fc_classify" value="&lt;b&gt;_classify(name_score, addr_score, bucket_rules)&lt;/b&gt;&lt;br&gt;For each bucket: if name_min ≤ name_score ≤ name_max AND addr_min ≤ addr_score ≤ addr_max → return bucket&lt;br&gt;Fallback: &lt;b&gt;NEEDS REVIEW&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#666;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="1335" width="850" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="fc1" value="&lt;b&gt;NEW BA AND NEW ADDRESS&lt;/b&gt;&lt;br&gt;Defaults: name 0–0, addr 0–0&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Config: NEW_BA_NEW_ADDR_{MIN|MAX}_{NAME|ADDR}_SCORE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1400" width="230" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="fc2" value="&lt;b&gt;EXISTING BA ADD NEW ADDRESS&lt;/b&gt;&lt;br&gt;Defaults: name 100–100, addr 0–0&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Config: EXISTING_BA_NEW_ADDR_{MIN|MAX}_{NAME|ADDR}_SCORE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="1400" width="260" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="fc3" value="&lt;b&gt;EXISTING BA AND EXISTING ADDRESS&lt;/b&gt;&lt;br&gt;Defaults: name 100–100, addr 100–100&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Config: EXISTING_BA_EXISTING_ADDR_{MIN|MAX}_{NAME|ADDR}_SCORE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="810" y="1400" width="280" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="fc4" value="&lt;b&gt;NEEDS REVIEW&lt;/b&gt;&lt;br&gt;(implicit fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1400" width="140" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="fc_note" value="Default ranges are intentionally narrow (0–0 or 100–100) — most records go to NEEDS REVIEW until ranges are tuned via Snowflake BA_CONFIG table. 12 config keys control the 3 bucket ranges." style="text;html=1;fontSize=10;fontColor=#666;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="1465" width="860" height="25" as="geometry"/>
        </mxCell>

        <!-- Arrows from scoring to final -->
        <mxCell id="a_name_to_final" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;" edge="1" parent="1" source="nc_formula" target="final_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a_google_to_final" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#00897B;strokeWidth=2;dashed=1;" edge="1" parent="1" source="google_group" target="final_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- TRUST DETECTION                                                  -->
        <!-- ================================================================ -->
        <mxCell id="trust_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="1510" width="1100" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="trust_title" value="&lt;b&gt;Trust Detection (is_trust flag)&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;fontColor=#8B5E3C;" vertex="1" parent="1">
          <mxGeometry x="500" y="1515" width="560" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="trust_regex" value="&lt;b&gt;Regex check on ALL of these fields (any match → is_trust=1):&lt;/b&gt;&lt;br&gt;Canvas name, Canvas address, DEC name (hdrname), DEC address (addraddress)&lt;br&gt;&lt;br&gt;TRUST | TRUSTEE | TRUSTEES | TRUSTEESHIP | TTEE | LIVING TRUST | FAMILY TRUST&lt;br&gt;REVOCABLE TRUST | IRREVOCABLE TRUST | TESTAMENTARY | ESTATE OF | DECEDENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1545" width="600" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="trust_output" value="&lt;b&gt;Trust mode normalization:&lt;/b&gt;&lt;br&gt;When trust detected, normalize_name/address&lt;br&gt;skip all processing — just UPPERCASE.&lt;br&gt;Produces composite trust score.&lt;br&gt;&lt;br&gt;Keywords from Snowflake BA_LOOKUP or defaults" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0C8B0;strokeColor=#D4A880;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="1545" width="420" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrow: final → trust -->
        <mxCell id="a_final_to_trust" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D4A880;strokeWidth=2;dashed=1;" edge="1" parent="1" source="final_group" target="trust_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PIPELINE FLOW LEGEND                                              -->
        <!-- ================================================================ -->
        <mxCell id="legend_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;arcSize=6;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
          <mxGeometry x="250" y="1670" width="1100" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="legend_title" value="&lt;b&gt;Pipeline Flow (sequential)&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="1675" width="560" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="lp1" value="&lt;b&gt;1.&lt;/b&gt; &lt;b&gt;Score:&lt;/b&gt; name_compare() → name_score (0–100), address_compare() → addr_score (0–100), same_address flag" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1705" width="1050" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lp2" value="&lt;b&gt;&lt;font color=&quot;#5C6BC0&quot;&gt;2.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#5C6BC0&quot;&gt;&lt;b&gt;Address-Name Boost:&lt;/b&gt; if name_score &amp;lt; 95, check supplementary sources (DEC contact, C/O, ATTN) → best wins, cap 0.95&lt;/font&gt;" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1728" width="1050" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lp3" value="&lt;b&gt;3.&lt;/b&gt; &lt;b&gt;Classify:&lt;/b&gt; _classify(name_score, addr_score, BUCKET_RULES) — 3 configurable buckets + NEEDS REVIEW fallback" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1751" width="1050" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lp4" value="&lt;b&gt;&lt;font color=&quot;#e67e22&quot;&gt;4.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#e67e22&quot;&gt;&lt;b&gt;Name API Override:&lt;/b&gt; name_score 15–70 with SSN match → Claude Sonnet 4.5 batches of 20 → override score → reclassify&lt;/font&gt;" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1774" width="1050" height="20" as="geometry"/>
        </mxCell>
