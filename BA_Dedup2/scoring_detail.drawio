        <mxCell id="nn4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Suffix Map Replacements&lt;/b&gt;&lt;br&gt;FEDERAL EXPRESS → FEDEX&lt;br&gt;Multi-word states: NEW YORK → NEWYORK&lt;br&gt;Trust: LIV TR → LIVING TRUST, REV/REVOC → REVOCABLE, TR → TRUST&lt;br&gt;CORPORATION → CORP, JUNIOR → JR, SENIOR → SR&lt;br&gt;L L C → LLC, L P → LP" vertex="1">
