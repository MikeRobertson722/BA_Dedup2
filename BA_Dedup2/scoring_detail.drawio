        </mxCell>
        <mxCell id="nc_token" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Tokenize &amp;amp; Clean Tokens&lt;/b&gt;&lt;br&gt;1. Strip NAME_SUFFIXES: JR, SR, II, III, IV, V&lt;br&gt;2. Acronym check: CSC = Corp Service Co → &lt;b&gt;95&lt;/b&gt;&lt;br&gt;3. Strip BUSINESS_SUFFIXES: LLC, INC, CORP, CO, LTD, LP...&lt;br&gt;4. Strip BUSINESS_DESCRIPTORS: SERVICES, HOLDINGS...&lt;br&gt;5. Strip &lt;b&gt;INDUSTRY_TERMS&lt;/b&gt;: EXPLORATION, DRILLING, OIL, GAS,&lt;br&gt;   PETROLEUM, ENERGY, RESOURCES, PIPELINE, MINERALS...&lt;br&gt;6. Strip AND, THE&lt;br&gt;7. &lt;b&gt;canonicalize_token()&lt;/b&gt; each remaining token" vertex="1">
          <mxGeometry height="130" width="380" x="80" y="455" as="geometry" />
        </mxCell>
        <mxCell id="a_exact_n" edge="1" parent="1" source="nc_exact" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=10;" target="nc_token" value="NO">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nc_canon" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;canonicalize_token()&lt;/b&gt;&lt;br&gt;NICKNAMES: JIMMY→JAMES, BOB→ROBERT...&lt;br&gt;NUMBER_WORDS: ONE→1, TWO→2...&lt;br&gt;STATE_ABBREVS: TX→TEXAS, OK→OKLAHOMA...&lt;br&gt;(skip IN, CO — ambiguous)" vertex="1">
          <mxGeometry height="85" width="230" x="490" y="460" as="geometry" />
        </mxCell>
        <mxCell id="nc_post_exact" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="Cleaned tokens equal?" vertex="1">
          <mxGeometry height="50" width="230" x="270" y="600" as="geometry" />
        </mxCell>
        <mxCell id="a_tok_to_post" edge="1" parent="1" source="nc_token" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=1.5;" target="nc_post_exact">
