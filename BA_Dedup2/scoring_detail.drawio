        <mxCell id="an5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;COUNTY ROAD → CR&lt;/b&gt;&lt;br&gt;(before street type norm)" vertex="1">
