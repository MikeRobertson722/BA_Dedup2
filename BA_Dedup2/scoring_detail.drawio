        </mxCell>
        <mxCell id="a_init_y" edge="1" parent="1" source="nc_initial" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" target="nc_init_yes" value="YES">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Multi-Strategy Similarity -->
        <mxCell id="nc_sim" parent="1" style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;Multi-Strategy Similarity&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="250" x="180" y="740" as="geometry" />
        </mxCell>
        <mxCell id="a_init_n" edge="1" parent="1" source="nc_initial" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=10;" target="nc_sim" value="NO">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nc_jw1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;" value="&lt;b&gt;Direct JW&lt;/b&gt;&lt;br&gt;jaro_winkler(c1, c2)" vertex="1">
          <mxGeometry height="40" width="170" x="60" y="770" as="geometry" />
        </mxCell>
        <mxCell id="nc_jw2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;" value="&lt;b&gt;Sorted JW&lt;/b&gt;&lt;br&gt;sort tokens alphabetically" vertex="1">
          <mxGeometry height="40" width="180" x="250" y="770" as="geometry" />
        </mxCell>
        <mxCell id="nc_jw3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;" value="&lt;b&gt;Compact JW&lt;/b&gt;&lt;br&gt;strip all non-alnum" vertex="1">
          <mxGeometry height="40" width="170" x="450" y="770" as="geometry" />
        </mxCell>
        <mxCell id="nc_best_jw" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673a6;fontSize=11;" value="&lt;b&gt;best_jw = max(direct, sorted, compact)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="380" x="155" y="825" as="geometry" />
        </mxCell>
        <mxCell id="nc_overlap" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;enhanced_token_overlap()&lt;/b&gt;&lt;br&gt;1. Exact token match&lt;br&gt;2. Initial match (J ↔ JOHN)&lt;br&gt;3. Fuzzy match (JW &amp;gt; 0.88, both tokens &amp;gt; 4 chars)&lt;br&gt;&lt;b&gt;Result:&lt;/b&gt; overlap_coeff = matched / smaller_set_size" vertex="1">
          <mxGeometry height="80" width="340" x="60" y="870" as="geometry" />
        </mxCell>
        <mxCell id="nc_bookend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Bookend Bonus&lt;/b&gt;&lt;br&gt;If first tokens match (exact, initial, &lt;br&gt;or JW ≥ 0.85) AND last tokens match:&lt;br&gt;&lt;b&gt;overlap_coeff = max(overlap, 0.90)&lt;/b&gt;" vertex="1">
          <mxGeometry height="75" width="290" x="420" y="870" as="geometry" />
        </mxCell>
        <mxCell id="nc_formula" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" value="&lt;b&gt;score = best_jw × (0.3 + 0.7 × overlap_coeff)&lt;/b&gt;&lt;br&gt;&lt;br&gt;If compact_jw ≥ 0.95: score = max(score, compact_jw)&lt;br&gt;&lt;br&gt;&lt;b&gt;Round to nearest 5, scale to 0–100&lt;/b&gt;" vertex="1">
          <mxGeometry height="70" width="420" x="150" y="960" as="geometry" />
        </mxCell>

        <!-- Address-Name Boost -->
        <mxCell id="boost_group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;arcSize=8;" value="" vertex="1">
          <mxGeometry height="200" width="700" x="40" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="boost_title" parent="1" style="text;html=1;fontSize=13;align=center;fontColor=#283593;" value="&lt;b&gt;Address-Name Boost (supplementary name sources, capped at 0.95)&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="500" x="140" y="1055" as="geometry" />
        </mxCell>
        <mxCell id="boost_sources" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;If primary name_score &amp;lt; 0.95, check supplementary sources (best wins):&lt;/b&gt;&lt;br&gt;1. DEC_CONTACT: Canvas name vs DEC addrcontact field&lt;br&gt;2. CANVAS_ADDR_NAME: names from Canvas address (C/O, ATTN patterns) vs DEC hdrname&lt;br&gt;3. CANVAS_ADDR+DEC_CONTACT: Canvas address names vs DEC addrcontact&lt;br&gt;4. DEC_ADDR_NAME: Canvas name vs names from DEC address field&lt;br&gt;5. CANVAS_ADDR+DEC_ADDR: Canvas address names vs DEC address names" vertex="1">
          <mxGeometry height="100" width="400" x="60" y="1085" as="geometry" />
        </mxCell>
        <mxCell id="boost_extract" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Name Extraction from Addresses:&lt;/b&gt;&lt;br&gt;• C/O &amp;lt;name&amp;gt; (before digits/PO BOX)&lt;br&gt;• ATTN: &amp;lt;name&amp;gt; (before digits/PO BOX)&lt;br&gt;• Strip role suffixes: MANAGER, AGENT,&lt;br&gt;  DIRECTOR, PRESIDENT, VP, etc." vertex="1">
          <mxGeometry height="100" width="240" x="480" y="1085" as="geometry" />
        </mxCell>
        <mxCell id="boost_note" parent="1" style="text;html=1;fontSize=10;fontColor=#5C6BC0;align=center;" value="All supplementary scores capped at &lt;b&gt;0.95&lt;/b&gt; — only applied if better than primary name_compare result" vertex="1">
          <mxGeometry height="15" width="580" x="100" y="1225" as="geometry" />
        </mxCell>
        <mxCell id="a_name_to_boost" edge="1" parent="1" source="nc_formula" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#5C6BC0;strokeWidth=2;dashed=1;" target="boost_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

