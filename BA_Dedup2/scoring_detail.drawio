        <mxCell id="po3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=6;" value="&lt;b&gt;Score = min(1.0, 0.92 × city_sim + zip_bonus)&lt;/b&gt;&lt;br&gt;zip_bonus = 0.05 if zips match&lt;br&gt;same = score ≥ 0.90 &amp;amp; city_sim ≥ 0.85" vertex="1">
