        </mxCell>
        <mxCell id="lp0" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;&lt;font color=&quot;#8B5E3C&quot;&gt;0.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#8B5E3C&quot;&gt;&lt;b&gt;Trust Detection:&lt;/b&gt; regex on Canvas name/address → is_trust flag (affects normalization mode for scoring)&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="1050" x="380" y="2245" as="geometry" />
        </mxCell>
        <mxCell id="lp1" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;1.&lt;/b&gt; &lt;b&gt;Score:&lt;/b&gt; name_compare() → name_score (0–100), address_compare() → addr_score (0–100), same_address flag" vertex="1">
          <mxGeometry height="20" width="1050" x="380" y="2268" as="geometry" />
        </mxCell>
        <mxCell id="lp2" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;&lt;font color=&quot;#5C6BC0&quot;&gt;2.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#5C6BC0&quot;&gt;&lt;b&gt;Address-Name Boost:&lt;/b&gt; if name_score &amp;lt; 95, check supplementary sources (DEC contact, C/O, ATTN) → best wins, cap 0.95&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="1050" x="380" y="2291" as="geometry" />
        </mxCell>
        <mxCell id="lp2b" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;&lt;font color=&quot;#C62828&quot;&gt;3.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;Data Quality Gate:&lt;/b&gt; _needs_review_override() — bad data → immediate NEEDS REVIEW; good data → deferred (rec=None)&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="1050" x="380" y="2314" as="geometry" />
        </mxCell>
        <mxCell id="lp3" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;&lt;font color=&quot;#E65100&quot;&gt;4a.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;Claude API:&lt;/b&gt; ambiguous name_score 15–70 with SSN match → Claude Sonnet 4.5 → update name_score only&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="1050" x="380" y="2337" as="geometry" />
        </mxCell>
        <mxCell id="lp4" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;&lt;font color=&quot;#00897B&quot;&gt;4b.&lt;/font&gt;&lt;/b&gt; &lt;font color=&quot;#00897B&quot;&gt;&lt;b&gt;Google API:&lt;/b&gt; ambiguous addr_score 15–65 (or zero-score rule) with SSN match → standardize → re-score → update addr_score only&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="1050" x="380" y="2360" as="geometry" />
        </mxCell>
        <mxCell id="lp5" parent="1" style="text;html=1;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;5.&lt;/b&gt; &lt;b&gt;Classify:&lt;/b&gt; single pass — _classify(name_score, addr_score, BUCKET_RULES) with final enriched scores → 3 buckets + NEEDS REVIEW" vertex="1">
