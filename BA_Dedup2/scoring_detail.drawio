        </mxCell>
        <mxCell id="an6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;" value="Strip &lt;b&gt;. , -&lt;/b&gt; and collapse spaces" vertex="1">
          <mxGeometry height="30" width="190" x="1280" y="260" as="geometry" />
        </mxCell>
