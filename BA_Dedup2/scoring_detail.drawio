        <mxCell id="addr_street_title" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;" value="&lt;b&gt;Street Address Path&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="160" x="1300" y="495" as="geometry" />
        </mxCell>
        <mxCell id="a_classify_st" edge="1" parent="1" source="addr_classify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;fontSize=10;" target="addr_street_group" value="STREET">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st0" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=10;" value="Either has house number?" vertex="1">
          <mxGeometry height="40" width="220" x="1260" y="525" as="geometry" />
        </mxCell>
        <mxCell id="st_nonstandard" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=8;" value="&lt;b&gt;Non-Standard Path&lt;/b&gt;&lt;br&gt;(military: CMR/PSC/UNIT)&lt;br&gt;&lt;br&gt;addr_sim = max(JW(addr1,addr2), JW(compact1,compact2))&lt;br&gt;score = addr_sim × (0.6 + 0.4 × city_sim)&lt;br&gt;&lt;br&gt;Penalties:&lt;br&gt;  • embedded nums mismatch: −0.10&lt;br&gt;  • zip mismatch: −0.20&lt;br&gt;Bonus:&lt;br&gt;  • all nums match + zip match: +0.50" vertex="1">
          <mxGeometry height="150" width="230" x="1200" y="580" as="geometry" />
        </mxCell>
        <mxCell id="a_st0_no" edge="1" parent="1" source="st0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;fontSize=9;" target="st_nonstandard" value="NEITHER">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_one_missing" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" value="Score=0&lt;br&gt;MISSING_HOUSE_NUM" vertex="1">
          <mxGeometry height="35" width="110" x="1440" y="580" as="geometry" />
        </mxCell>
        <mxCell id="a_st0_one" edge="1" parent="1" source="st0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" target="st_one_missing" value="ONE">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=10;" value="House numbers match?" vertex="1">
          <mxGeometry height="40" width="200" x="1280" y="745" as="geometry" />
        </mxCell>
        <mxCell id="a_st0_both" edge="1" parent="1" source="st0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="st1" value="BOTH">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1370" y="730" />
              <mxPoint x="1380" y="730" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="st1_no" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" value="Score=0&lt;br&gt;HOUSE_NUM_MISMATCH" vertex="1">
          <mxGeometry height="35" width="110" x="1440" y="740" as="geometry" />
        </mxCell>
        <mxCell id="a_st1_no" edge="1" parent="1" source="st1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;" target="st1_no" value="NO">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_core" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;street_core_for_match()&lt;/b&gt;&lt;br&gt;Strip: house num, street types,&lt;br&gt;directions, unit tokens&lt;br&gt;→ pure street name" vertex="1">
          <mxGeometry height="65" width="220" x="1220" y="805" as="geometry" />
        </mxCell>
        <mxCell id="a_st1_yes" edge="1" parent="1" source="st1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;" target="st_core" value="YES">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_formula" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" value="&lt;b&gt;street_sim&lt;/b&gt; = max(JW(core1,core2), JW(compact1,compact2))&lt;br&gt;&lt;b&gt;city_sim&lt;/b&gt; = max(JW(city1,city2), JW(compact_cities))&lt;br&gt;&lt;br&gt;&lt;b&gt;score = street_sim × (0.6 + 0.4 × city_sim)&lt;/b&gt;&lt;br&gt;&lt;br&gt;If zip match &amp;amp; score ≥ 0.85: &lt;b&gt;+0.05&lt;/b&gt;&lt;br&gt;If zip mismatch &amp;amp; city_sim &amp;lt; 0.92: &lt;b&gt;×0.75&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;same = street_sim ≥ 0.90 &amp;amp; zip_ok &amp;amp; city_sim ≥ 0.85&lt;/b&gt;" vertex="1">
          <mxGeometry height="130" width="340" x="1200" y="890" as="geometry" />
        </mxCell>
        <mxCell id="a_core_to_formula" edge="1" parent="1" source="st_core" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1.5;" target="st_formula">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- DATA QUALITY GATE                                             -->
        <!-- ============================================================ -->
        <mxCell id="dq_group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="1100" x="360" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="dq_title" parent="1" style="text;html=1;fontSize=14;align=center;fontColor=#B71C1C;" value="&lt;b&gt;Data Quality Gate — _needs_review_override()&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="560" x="610" y="1285" as="geometry" />
        </mxCell>
        <mxCell id="dq_checks" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Canvas fields:&lt;/b&gt; EMPTY_NAME, EMPTY_ADDRESS, EMPTY_CITY, EMPTY_STATE, EMPTY_ZIP,&lt;br&gt;UNKNOWN_ADDRESS (regex), UNKNOWN_CITY, UNKNOWN_NAME&lt;br&gt;&lt;br&gt;&lt;b&gt;DEC fields (when matched):&lt;/b&gt; DEC_EMPTY_NAME, DEC_EMPTY_ADDRESS, DEC_EMPTY_CITY,&lt;br&gt;DEC_EMPTY_STATE, DEC_EMPTY_ZIP, DEC_UNKNOWN_ADDRESS, DEC_UNKNOWN_CITY" vertex="1">
          <mxGeometry height="80" width="530" x="380" y="1315" as="geometry" />
        </mxCell>
        <mxCell id="dq_outcome" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;If any check fails:&lt;/b&gt;&lt;br&gt;• recommendation = NEEDS REVIEW (immediate, not deferred)&lt;br&gt;• Skips API enrichment — scores stay as-is&lt;br&gt;• Also forced for UNKNOWN_ADDRESS (addr reason check)&lt;br&gt;&lt;br&gt;&lt;b&gt;If all checks pass:&lt;/b&gt;&lt;br&gt;• recommendation = None (deferred to final classification)" vertex="1">
          <mxGeometry height="100" width="390" x="940" y="1315" as="geometry" />
        </mxCell>
        <mxCell id="a_boost_to_dq" edge="1" parent="1" source="boost_group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=2;dashed=1;" target="dq_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_addr_to_dq" edge="1" parent="1" source="st_formula" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=2;dashed=1;" target="dq_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- API SCORE ENRICHMENT (Claude + Google)                        -->
        <!-- ============================================================ -->
        <mxCell id="api_group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;arcSize=8;" value="" vertex="1">
          <mxGeometry height="310" width="1100" x="360" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="api_title" parent="1" style="text;html=1;fontSize=14;align=center;fontColor=#BF360C;" value="&lt;b&gt;API Score Enrichment — Update Scores Only (no classification yet)&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="700" x="560" y="1485" as="geometry" />
        </mxCell>

        <!-- Claude API sub-section -->
        <mxCell id="claude_sub" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;arcSize=6;" value="" vertex="1">
          <mxGeometry height="130" width="500" x="380" y="1515" as="geometry" />
        </mxCell>
        <mxCell id="claude_title" parent="1" style="text;html=1;fontSize=12;align=center;fontColor=#BF360C;" value="&lt;b&gt;Claude API — Name Score Override&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="400" x="430" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="claude_filter" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Filter:&lt;/b&gt; SSN match (ssn_match=100) AND&lt;br&gt;  name_score between API_SCORE_MIN–API_SCORE_MAX&lt;br&gt;  (defaults: 15–70, configurable in BA_CONFIG)" vertex="1">
          <mxGeometry height="50" width="230" x="395" y="1545" as="geometry" />
        </mxCell>
        <mxCell id="claude_action" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Action:&lt;/b&gt; Send name pairs to Claude Sonnet 4.5&lt;br&gt;in batches of 20 for semantic evaluation&lt;br&gt;&lt;br&gt;&lt;b&gt;Result:&lt;/b&gt; Update name_score only&lt;br&gt;(no classification, no stat changes)" vertex="1">
          <mxGeometry height="80" width="230" x="640" y="1545" as="geometry" />
        </mxCell>

        <!-- Google API sub-section -->
        <mxCell id="google_sub" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;arcSize=6;" value="" vertex="1">
          <mxGeometry height="130" width="1060" x="380" y="1650" as="geometry" />
        </mxCell>
        <mxCell id="google_title" parent="1" style="text;html=1;fontSize=12;align=center;fontColor=#004D40;" value="&lt;b&gt;Google Address Validation API — Address Score Override&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="500" x="650" y="1655" as="geometry" />
        </mxCell>
        <mxCell id="google_filter" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Filter:&lt;/b&gt; SSN match (ssn_match=100) AND&lt;br&gt;  addr_score 15–65 (GOOGLE_ADDR_SCORE_MIN/MAX)&lt;br&gt;  &lt;b&gt;OR zero-score rule:&lt;/b&gt; score=0 but zips match,&lt;br&gt;  all embedded nums match, both have ≥1 number" vertex="1">
          <mxGeometry height="65" width="310" x="395" y="1680" as="geometry" />
        </mxCell>
        <mxCell id="google_validate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2DFDB;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;google_validate_address()&lt;/b&gt;&lt;br&gt;1. Check in-memory cache (pre-loaded from Snowflake)&lt;br&gt;2. Call Google Address Validation API if miss&lt;br&gt;3. Persist to google_address_lookups table&lt;br&gt;4. Return: standardized (addr,city,state,zip) + verdict" vertex="1">
          <mxGeometry height="80" width="330" x="720" y="1680" as="geometry" />
        </mxCell>
        <mxCell id="google_rescore" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2DFDB;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Re-score (score update only):&lt;/b&gt;&lt;br&gt;1. Replace Canvas+DEC addrs with standardized&lt;br&gt;2. Re-run address_compare() on standardized pair&lt;br&gt;3. Update address_score&lt;br&gt;(no classification, no stat changes)" vertex="1">
          <mxGeometry height="80" width="300" x="1060" y="1680" as="geometry" />
        </mxCell>
        <mxCell id="a_dq_to_api" edge="1" parent="1" source="dq_group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;" target="api_group" value="scores (not yet classified)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- FINAL CLASSIFICATION — Single Pass                            -->
        <!-- ============================================================ -->
        <mxCell id="final_group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;arcSize=6;" value="" vertex="1">
          <mxGeometry height="200" width="1100" x="360" y="1830" as="geometry" />
        </mxCell>
        <mxCell id="final_title" parent="1" style="text;html=1;fontSize=14;align=center;" value="&lt;b&gt;Final Classification — Single Pass with Best Available Scores&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="700" x="560" y="1835" as="geometry" />
        </mxCell>
        <mxCell id="fc_classify" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#666;fontSize=11;align=center;" value="&lt;b&gt;_classify(name_score, addr_score, bucket_rules)&lt;/b&gt;&lt;br&gt;For each bucket: if name_min ≤ name_score ≤ name_max AND addr_min ≤ addr_score ≤ addr_max → return bucket&lt;br&gt;Fallback: &lt;b&gt;NEEDS REVIEW&lt;/b&gt;&lt;br&gt;&lt;br&gt;Records already forced to NEEDS REVIEW by data quality gate are &lt;b&gt;not re-classified&lt;/b&gt; (recommendation ≠ None)" vertex="1">
          <mxGeometry height="65" width="850" x="460" y="1865" as="geometry" />
        </mxCell>
        <mxCell id="fc1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#666;fontSize=10;" value="&lt;b&gt;NEW BA AND NEW ADDRESS&lt;/b&gt;&lt;br&gt;Defaults: name 0–0, addr 0–0&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Config: NEW_BA_NEW_ADDR_{MIN|MAX}_{NAME|ADDR}_SCORE&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="230" x="390" y="1940" as="geometry" />
        </mxCell>
        <mxCell id="fc2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="&lt;b&gt;EXISTING BA ADD NEW ADDRESS&lt;/b&gt;&lt;br&gt;Defaults: name 100–100, addr 0–0&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Config: EXISTING_BA_NEW_ADDR_{MIN|MAX}_{NAME|ADDR}_SCORE&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="260" x="640" y="1940" as="geometry" />
        </mxCell>
        <mxCell id="fc3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="&lt;b&gt;EXISTING BA AND EXISTING ADDRESS&lt;/b&gt;&lt;br&gt;Defaults: name 100–100, addr 100–100&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Config: EXISTING_BA_EXISTING_ADDR_{MIN|MAX}_{NAME|ADDR}_SCORE&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="280" x="920" y="1940" as="geometry" />
        </mxCell>
        <mxCell id="fc4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" value="&lt;b&gt;NEEDS REVIEW&lt;/b&gt;&lt;br&gt;(implicit fallback)" vertex="1">
          <mxGeometry height="55" width="140" x="1220" y="1940" as="geometry" />
        </mxCell>
        <mxCell id="fc_note" parent="1" style="text;html=1;fontSize=10;fontColor=#666;align=center;" value="Default ranges are intentionally narrow (0–0 or 100–100) — most records go to NEEDS REVIEW until ranges are tuned via Snowflake BA_CONFIG table. 12 config keys control the 3 bucket ranges." vertex="1">
          <mxGeometry height="25" width="860" x="460" y="2000" as="geometry" />
        </mxCell>
        <mxCell id="a_api_to_final" edge="1" parent="1" source="api_group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;strokeWidth=2;" target="final_group" value="final scores">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- TRUST DETECTION                                               -->
        <!-- ============================================================ -->
        <mxCell id="trust_group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="1100" x="360" y="2050" as="geometry" />
        </mxCell>
        <mxCell id="trust_title" parent="1" style="text;html=1;fontSize=14;align=center;fontColor=#8B5E3C;" value="&lt;b&gt;Trust Detection (is_trust flag — set before scoring)&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="560" x="610" y="2055" as="geometry" />
        </mxCell>
        <mxCell id="trust_regex" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Regex check on ALL of these fields (any match → is_trust=1):&lt;/b&gt;&lt;br&gt;Canvas name, Canvas address, DEC name (hdrname), DEC address (addraddress)&lt;br&gt;&lt;br&gt;TRUST | TRUSTEE | TRUSTEES | TRUSTEESHIP | TTEE | LIVING TRUST | FAMILY TRUST&lt;br&gt;REVOCABLE TRUST | IRREVOCABLE TRUST | TESTAMENTARY | ESTATE OF | DECEDENT" vertex="1">
          <mxGeometry height="80" width="600" x="380" y="2085" as="geometry" />
        </mxCell>
        <mxCell id="trust_output" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0C8B0;strokeColor=#D4A880;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Trust mode normalization:&lt;/b&gt;&lt;br&gt;When trust detected, normalize_name/address&lt;br&gt;skip all processing — just UPPERCASE.&lt;br&gt;Produces composite trust score.&lt;br&gt;&lt;br&gt;Keywords from Snowflake BA_LOOKUP or defaults" vertex="1">
          <mxGeometry height="80" width="420" x="1010" y="2085" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- PIPELINE FLOW LEGEND                                          -->
