        <mxCell id="an0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF0E0;strokeColor=#D4A880;fontSize=10;fontStyle=2;" value="&lt;b&gt;Trust mode:&lt;/b&gt; if trust=True → just UPPERCASE + collapse whitespace, skip all below" vertex="1">
          <mxGeometry height="25" width="680" x="820" y="105" as="geometry" />
        </mxCell>
        <mxCell id="an_dates" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Strip Dates&lt;/b&gt;&lt;br&gt;Remove DATED prefix&lt;br&gt;Strip: JUNE 14 2012, MAR 2012&lt;br&gt;Strip: MM/DD/YYYY, MM-DD-YYYY" vertex="1">
          <mxGeometry height="70" width="200" x="820" y="140" as="geometry" />
        </mxCell>
        <mxCell id="an1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;PO Box Canonicalization&lt;/b&gt;&lt;br&gt;POST OFFICE BOX / P.O. BOX → PO BOX&lt;br&gt;POB / POP BOX → PO BOX&lt;br&gt;BOX 5 → PO BOX 5 (if entire line)&lt;br&gt;PO BOX ONE → PO BOX 1" vertex="1">
          <mxGeometry height="80" width="220" x="1040" y="140" as="geometry" />
        </mxCell>
        <mxCell id="an2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Direction Normalization&lt;/b&gt;&lt;br&gt;NORTHEAST → NE, NORTH → N&lt;br&gt;SOUTH → S, EAST → E, WEST → W" vertex="1">
          <mxGeometry height="60" width="220" x="1280" y="140" as="geometry" />
        </mxCell>
        <mxCell id="an3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Street Type Abbreviation&lt;/b&gt;&lt;br&gt;STREET→ST, AVENUE→AVE, BOULEVARD→BLVD&lt;br&gt;DRIVE→DR, ROAD→RD, LANE→LN, COURT→CT&lt;br&gt;HIGHWAY→HWY, PARKWAY→PKWY, TRAIL→TRL" vertex="1">
          <mxGeometry height="65" width="250" x="820" y="220" as="geometry" />
        </mxCell>
        <mxCell id="an4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;Unit Abbreviation&lt;/b&gt;&lt;br&gt;APARTMENT→APT, SUITE→STE&lt;br&gt;BUILDING→BLDG, FLOOR→FL, ROOM→RM&lt;br&gt;#123 → APT 123" vertex="1">
          <mxGeometry height="65" width="220" x="1090" y="220" as="geometry" />
